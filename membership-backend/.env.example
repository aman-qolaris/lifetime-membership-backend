# Copy this file to `.env` and fill values.
# IMPORTANT: Never commit real production secrets.

# ======================
# Server
# ======================
PORT=3000
NODE_ENV=development

# ======================
# Database (MySQL)
# ======================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=membership_db

# Optional: for test runs (SQLite). Only used when DB_DIALECT=sqlite
# DB_DIALECT=sqlite
# DB_STORAGE=:memory:

# ======================
# MinIO (file storage)
# ======================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=changeme
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_NAME=membership-uploads

# ======================
# Email SMTP
# ======================
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=changeme
SMTP_PASS=changeme

# Used for generating approval/payment URLs in emails
FRONTEND_URL=http://localhost:5173

# ======================
# Razorpay
# ======================
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ======================
# JWT
# ======================
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=12h

# Optional: applicant Socket.io token expiry
APPLICANT_SOCKET_JWT_EXPIRES_IN=30d

# ======================
# Redis (recommended for multi-instance)
# Enables: shared cache (settings/regions), shared rate limiting, socket.io redis adapter
# ======================
# REDIS_URL=redis://localhost:6379

# Socket.io CORS (comma-separated origins). If unset, backend currently allows "*".
CORS_ORIGIN=http://localhost:5173

# ======================
# Rate limiting
# ======================
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=300
# RATE_LIMIT_LOGIN_WINDOW_MS=900000
# RATE_LIMIT_LOGIN_MAX=10

# ======================
# Seeder (required for `npm run seed`)
# ======================
SEED_ADMIN_PHONE_NUMBER=9999999999
SEED_ADMIN_PASSWORD=changeme
